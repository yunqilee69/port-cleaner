{
  "name": "port-cleaner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify:release": "node scripts/verify-release-metadata.mjs",
    "test:release-metadata": "node --test scripts/verify-release-metadata.test.mjs",
    "test:desktop-config": "node --test scripts/desktop-config.test.mjs",
    "test:ui-style": "node --test scripts/ui-style.test.mjs",
    "check": "npm run verify:release && npm run test:release-metadata && npm run test:desktop-config && npm run test:ui-style && npm test && npm run build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
